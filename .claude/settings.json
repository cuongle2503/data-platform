{
  "rules": [
    ".claude/rules/common",
    ".claude/rules/python"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "glob": "**/*.py",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && uv run ruff format \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null; exit 0"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "glob": "**/git commit*",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && uv run ruff check . 2>&1 | head -n 50; uv run mypy . 2>&1 | head -n 50; exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[ECC] Reminder: Run /verification-loop before creating a PR'; exit 0"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Uv *",
      "Python *",
      "Pytest *",
      "Ruff *",
      "Mypy *",
      "Dbt *",
      "Airflow *",
      "Git *"
    ],
    "deny": []
  }
}
